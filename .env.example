# Texas AI Report — environment variables
# Copy to .env for local dev. Real values are set in the Vercel project's
# Environment Variables, NOT committed to the repo.

# Newsletter form action URL — ESP is Beehiiv.
# Set this to the Beehiiv embed form action URL found in your Beehiiv publication's
# embed/subscribe-form code (Beehiiv dashboard → Publication Settings → Embed & Subscribe Form).
# Consumed by src/components/Newsletter.astro. PUBLIC_ prefix = exposed in client HTML (safe; it's just a form POST endpoint).
PUBLIC_NEWSLETTER_ACTION=
