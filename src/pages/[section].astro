---
import Base from '../layouts/Base.astro';
import StoryCard from '../components/StoryCard.astro';
import { getCollection } from 'astro:content';
import { SECTIONS } from '../config/site';
export async function getStaticPaths(){ return SECTIONS.map(s=>({params:{section:s}})); }
const { section } = Astro.params;
const items=(await getCollection('news')).filter(e=>!e.data.draft && e.data.section===section)
  .sort((a,b)=>+b.data.publishDate-+a.data.publishDate);
---
<Base title={`${section} — Texas AI Report`} description={`Texas AI ${section} coverage.`}>
  <div class="wrap" style="padding:24px 20px">
    <h1 style="text-transform:capitalize;color:var(--navy)">{section}</h1>
    {items.map(e=><StoryCard entry={e}/>)}
  </div>
</Base>
