---
import Base from '../layouts/Base.astro';
import { SITE } from '../config/site';
const title = `Ownership & Disclosure — ${SITE.name}`;
const description = 'Who owns Texas AI Report and how affiliated relationships are disclosed.';
---
<Base title={title} description={description}>
  <div class="col" style="padding-top:40px;padding-bottom:48px">
    <div class="kicker">Disclosure</div>
    <h1 style="margin:8px 0 24px;color:var(--navy)">Ownership &amp; Disclosure</h1>

    <h2 style="color:var(--navy);font-size:18px;margin-bottom:8px">Ownership</h2>
    <p>
      Texas AI Report is owned and operated by Matthew Bertram, an individual
      based in Houston, Texas. It is not owned by a media corporation, investor
      syndicate, or government entity.
    </p>

    <h2 style="color:var(--navy);font-size:18px;margin-top:32px;margin-bottom:8px">Affiliated Entity</h2>
    <p>
      Texas AI Report has one affiliated commercial organization, through common
      ownership:
    </p>
    <ul style="padding-left:20px;margin-top:8px">
      <li>
        <strong><a href="https://modalpoint.com/">ModalPoint</a></strong> — An
        AI-governance advisory that helps organizations design, assess, and
        implement responsible AI programs. Matthew Bertram owns and leads
        ModalPoint. ModalPoint is also the Report's launch sponsor (see Funding,
        below).
      </li>
    </ul>

    <h2 style="color:var(--navy);font-size:18px;margin-top:32px;margin-bottom:8px">Funding</h2>
    <p>
      Texas AI Report is supported by sponsorship from <strong>ModalPoint</strong>,
      the affiliated company described above, as our launch sponsor. Any sponsored
      or advertising placement is clearly labeled and kept separate from our
      reporting; sponsors and advertisers have no say over coverage and do not see
      articles before they publish. New funding arrangements will be disclosed
      prominently on this page and within affected content.
    </p>

    <h2 style="color:var(--navy);font-size:18px;margin-top:32px;margin-bottom:8px">Editorial Independence</h2>
    <p>
      Coverage decisions are made editorially and are independent of ModalPoint's
      commercial interests. Sponsorship and common ownership do not give ModalPoint
      any right to approve, suppress, or shape coverage.
    </p>

    <h2 style="color:var(--navy);font-size:18px;margin-top:32px;margin-bottom:8px">Inline Disclosures</h2>
    <p>
      When a published story references ModalPoint or any other entity with which
      the publisher has a material relationship, that relationship is disclosed
      inline within the article — not only on this page. Readers should not have to
      navigate here to know about a potential conflict of interest in a specific
      story.
    </p>
  </div>
</Base>
