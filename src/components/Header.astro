---
import { SITE } from '../config/site';
---
<header style="border-bottom:1px solid var(--line)">
  <div class="wrap" style="display:flex;align-items:center;justify-content:space-between;padding:12px 20px">
    <a href="/" style="display:flex;align-items:center;gap:8px;text-decoration:none">
      <span style="width:5px;height:20px;background:var(--amber);border-radius:2px;display:inline-block"></span>
      <span style="font-weight:800;letter-spacing:-.02em;color:var(--navy);font-size:18px">TEXAS AI REPORT</span>
    </a>
    <nav style="display:flex;gap:16px;align-items:center;font-size:14px">
      <a href="/policy">Policy</a><a href="/business">Business</a>
      <a href="#newsletter" style="background:var(--amber);color:var(--ink);font-weight:800;padding:6px 12px;border-radius:5px;text-decoration:none">Subscribe</a>
    </nav>
  </div>
</header>
