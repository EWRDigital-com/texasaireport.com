---
import { MATT } from '../config/site';
---
<div style="display:flex;gap:10px;border:1px solid var(--line);border-radius:8px;padding:12px;margin-top:16px">
  <div style="width:44px;height:44px;border-radius:50%;background:var(--navy);flex:0 0 44px"></div>
  <div style="font-size:13px">
    <div style="font-weight:700;color:var(--navy)">{MATT.name}</div>
    <div style="color:var(--muted)">{MATT.role} · {MATT.credentials}. <a href={MATT.url}>matthewbertram.com →</a></div>
  </div>
</div>
