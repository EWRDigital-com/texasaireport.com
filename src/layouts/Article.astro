---
import Base from './Base.astro';
import KeyPoints from '../components/KeyPoints.astro';
import AuthorCard from '../components/AuthorCard.astro';
import Newsletter from '../components/Newsletter.astro';
import JsonLd from '../components/JsonLd.astro';
import { articleSchema, faqPageSchema } from '../lib/schema';
import { MATT } from '../config/site';
const { data, url, related = [] } = Astro.props;
const schema = articleSchema({ title:data.title, dek:data.dek, url,
  publishDate:data.publishDate, updatedDate:data.updatedDate, image:data.heroImage, section:data.section });
const faqs = data.faqs ?? [];
const fmt = (d:Date)=> d.toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric',timeZone:'UTC'});
---
<Base title={`${data.title} — Texas AI Report`} description={data.dek} image={data.heroImage} ogType="article" publishedTime={data.publishDate.toISOString()}>
  <JsonLd data={schema}/>
  {faqs.length>0 && <JsonLd data={faqPageSchema(faqs)}/>}
  <article class="col" style="padding-top:24px">
    <div class="kicker">{data.section}</div>
    <h1 style="font-size:30px;line-height:1.18;color:var(--navy);margin:8px 0 0">{data.title}</h1>
    <p style="font-size:13px;color:var(--muted);margin:10px 0 0">
      By <a href={MATT.url} rel="author" style="font-weight:700">{MATT.name}</a> ·
      <time datetime={data.publishDate.toISOString()}>{fmt(data.publishDate)}</time>
    </p>
    <p style="font-size:12px;color:var(--muted);margin:4px 0 0">Last reviewed {fmt(data.updatedDate ?? data.publishDate)}</p>
    <KeyPoints points={data.keyPoints}/>
    {data.heroImage && <figure style="margin:0 0 16px"><img src={data.heroImage} alt={data.heroCaption ?? data.title}/>{data.heroCaption && <figcaption style="font-size:12px;color:var(--muted)">{data.heroCaption}</figcaption>}</figure>}
    <div style="font-size:18px;line-height:1.6"><slot/></div>
    {faqs.length>0 &&
      <section aria-label="Frequently asked questions" style="margin:28px 0 0;border-top:1px solid var(--line);padding-top:18px">
        <h2 style="font-size:21px;color:var(--navy);margin:0 0 12px">Frequently asked questions</h2>
        <div style="display:grid;gap:16px">
          {faqs.map((f:{q:string;a:string})=>
            <div>
              <h3 style="font-size:16px;color:var(--navy);margin:0 0 5px">{f.q}</h3>
              <p style="font-size:15px;line-height:1.55;color:#27313f;margin:0">{f.a}</p>
            </div>)}
        </div>
      </section>}
    {data.modalpointRelevant &&
      <p style="background:#f5f8fb;border:1px solid #d8e2ee;border-radius:6px;padding:10px 12px;font-size:12px;color:#3f5168;margin:16px 0">
        <strong>Disclosure:</strong> Texas AI Report is published by {MATT.name}, who also leads
        <a href="https://modalpoint.com/">ModalPoint</a>, an AI-governance advisory. See our
        <a href="/editorial-standards">editorial standards</a>.</p>}
    {related.length>0 &&
      <nav aria-label="Related coverage" style="margin:24px 0;border-top:1px solid var(--line);padding-top:16px">
        <div style="font-size:12px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--muted);margin-bottom:10px">Related coverage</div>
        <ul style="list-style:none;padding:0;margin:0;display:grid;gap:10px">
          {related.map((r:any)=>
            <li><a href={`/news/${r.slug}`} style="color:var(--navy);font-weight:600;text-decoration:none;font-size:15px;line-height:1.35">{r.title}</a></li>)}
        </ul>
      </nav>}
    <Newsletter/>
    <AuthorCard/>
    {data.tags.length>0 && <div style="margin-top:12px;display:flex;gap:6px;flex-wrap:wrap">{data.tags.map((t:string)=><a href={`/tags/${t.toLowerCase().replace(/\s+/g,'-')}`} style="font-size:11px;background:#eef2f6;color:var(--navy);border-radius:20px;padding:4px 10px;text-decoration:none">{t}</a>)}</div>}
    <p style="font-size:12px;color:var(--muted);margin-top:18px;border-top:1px solid var(--line);padding-top:12px">Analysis and commentary, not legal advice.</p>
  </article>
</Base>
